{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": ["python3", "python3Packages.pip"]
        },
        "install": {
          "cmds": ["pip install -r backend/requirements.txt"]
        },
        "start": {
          "cmds": ["uvicorn backend.app.main:app --host 0.0.0.0 --port $PORT"]
        }
      }
    }
  },
  "deploy": {
    "numReplicas": 1
  }
}
